# ===========================================
# NexusNFT Contracts Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Network Configuration
# ===========================================

# Deployer Private Key (REQUIRED for deployment)
# WARNING: Never use a mainnet private key with real funds for testing!
# Generate a new wallet for deployment testing
SEPOLIA_PRIVATE_KEY=your_sepolia_private_key_here

# Sepolia RPC URL (REQUIRED)
# Get free RPC from: https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Mainnet Configuration (Optional - for production deployment)
# MAINNET_PRIVATE_KEY=your_mainnet_private_key
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ===========================================
# API Keys
# ===========================================

# Etherscan API Key (REQUIRED for contract verification)
# Get free key at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ===========================================
# Contract Configuration
# ===========================================

# Fee Recipient Address (REQUIRED)
# Address that will receive 1.5% marketplace fees
# For mainnet: Use a multi-sig wallet (recommended: Gnosis Safe)
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# ===========================================
# Optional Network Configurations
# ===========================================

# Polygon
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# POLYGON_PRIVATE_KEY=your_polygon_private_key

# Arbitrum
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARBITRUM_PRIVATE_KEY=your_arbitrum_private_key

# Optimism
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# OPTIMISM_PRIVATE_KEY=your_optimism_private_key
