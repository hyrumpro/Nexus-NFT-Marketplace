# ===========================================
# NexusNFT Frontend Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# Network / Explorer
# ===========================================
# Set to true when deploying on a testnet (Sepolia). When enabled (and on
# a known network), confirmed transactions show a "View on Explorer" link
# in the toast notification pointing to the correct block explorer.
NEXT_PUBLIC_IS_TESTNET=true

# ===========================================
# RPC URL for server-side approval checks (/api/check-approval)
# This is NOT exposed to the browser — no NEXT_PUBLIC_ prefix.
# If left empty, viem falls back to the chain's default public RPC.
# ===========================================
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key_here


NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NexusNFT
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# ===========================================
# RPC (browser-side) — used by wagmi transport
# ===========================================
# Optional: provide a private RPC for better reliability
# Falls back to the public Sepolia RPC if omitted
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# ===========================================
# Wallet Connection (REQUIRED for multi-wallet)
# ===========================================
# Get your project ID at: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ===========================================
# Core Marketplace Contracts
# Deploy contracts first, then update these addresses
# ===========================================
NEXT_PUBLIC_COLLECTION_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# The Graph Configuration (REQUIRED for data)
# SERVER-SIDE ONLY — never exposed to the browser.
# ===========================================
# Deploy subgraph to The Graph Studio, then copy the API URL
# https://thegraph.com/studio/
GRAPH_API_URL=https://api.studio.thegraph.com/query/your-subgraph-id
# Optional: API key for authenticated Graph Network queries
GRAPH_API_KEY=your_graph_api_key_here_optional

# ===========================================
# IPFS Configuration (REQUIRED for NFT uploads)
# SERVER-SIDE ONLY — never exposed to the browser.
# ===========================================
# Create account at: https://www.pinata.cloud/
# Go to API Keys and create a new key
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# ===========================================
# Deployment Instructions
# ===========================================
# 
# 1. Deploy Contracts:
#    cd contracts
#    cp .env.example .env
#    # Edit .env with your values
#    pnpm hardhat run scripts/deploy.ts --network sepolia
#
# 2. Copy the printed addresses to this file
#
# 3. Deploy Subgraph:
#    cd subgraph
#    # Update subgraph.yaml with contract addresses
#    graph codegen && graph build
#    graph deploy --studio nexusnft
#
# 4. Copy the Graph API URL to GRAPH_API_URL
#
# 5. Start Frontend:
#    cd frontend
#    npm run dev
