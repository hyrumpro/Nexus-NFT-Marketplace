# ===========================================
# NexusNFT Subgraph Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# Run "npm run prepare" (or any script that calls it) to stamp
# these values into subgraph.yaml before building.

# ===========================================
# The Graph Studio
# Get your deploy key from: https://thegraph.com/studio/
# (Settings → Deploy Key)
# ===========================================
GRAPH_DEPLOY_KEY=your_graph_deploy_key_here

# Subgraph name as registered in The Graph Studio
SUBGRAPH_NAME=nexusnft

# ===========================================
# Contract Addresses
# Fill in AFTER deploying contracts:
#   cd ../contracts
#   pnpm hardhat run scripts/deploy.ts --network sepolia
# The deploy script prints the addresses to stdout.
# ===========================================
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
COLLECTION_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# Network & Indexing
# ===========================================
# Target network (must match a network supported by The Graph)
NETWORK=sepolia

# Block number at which the earliest contract was deployed.
# Using the exact deployment block makes initial indexing much faster.
# Find it on Sepolia Etherscan under the contract's creation transaction.
START_BLOCK=0
